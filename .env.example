# Copy to .env and fill in from your Xero app (developer.xero.com > your app > Configuration).
# .env is gitignored. Never commit real values.
XERO_CLIENT_ID=your-client-id-here
XERO_CLIENT_SECRET=your-client-secret-here

# Optional: loopback port for the authorize.py redirect (default 8723).
# If you change it, register the matching redirect URI in the Xero app portal:
#   http://localhost:<port>/callback
# XERO_REDIRECT_PORT=8723
